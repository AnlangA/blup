{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sandbox_request.v1.schema.json",
  "title": "SandboxRequest",
  "description": "Request to execute code in a sandboxed environment",
  "type": "object",
  "required": ["request_id", "session_id", "tool_kind", "code"],
  "properties": {
    "request_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique request identifier"
    },
    "session_id": {
      "type": "string",
      "format": "uuid",
      "description": "Learning session ID"
    },
    "tool_kind": {
      "type": "string",
      "enum": ["python_exec", "node_exec", "typescript_compile_run", "rust_compile_run", "go_compile_run", "c_compile_run", "cpp_compile_run", "java_compile_run", "ruby_exec", "bash_exec", "typst_compile"],
      "description": "Type of sandbox tool to use"
    },
    "code": {
      "type": "string",
      "description": "Source code or input to execute"
    },
    "language": {
      "type": "string",
      "enum": ["python", "javascript", "typescript", "rust", "go", "c", "cpp", "java", "ruby", "bash", "typst"],
      "description": "Programming language"
    },
    "limits": {
      "type": "object",
      "description": "Resource limits for execution",
      "properties": {
        "compile_timeout_secs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120,
          "default": 30
        },
        "run_timeout_secs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60,
          "default": 10
        },
        "memory_mb": {
          "type": "integer",
          "minimum": 64,
          "maximum": 2048,
          "default": 512
        },
        "cpu_count": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 4,
          "default": 1
        },
        "disk_mb": {
          "type": "integer",
          "minimum": 10,
          "maximum": 1000,
          "default": 100
        },
        "network_enabled": {
          "type": "boolean",
          "default": false
        },
        "max_processes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 10
        }
      }
    },
    "stdin": {
      "type": "string",
      "description": "Optional piped input"
    },
    "environment": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Environment variables"
    }
  }
}
