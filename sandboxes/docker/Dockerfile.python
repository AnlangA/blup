FROM python:3.12-alpine

# Create sandbox user
RUN adduser -D -u 1000 sandbox

# Install common packages for data analysis (lightweight only)
RUN pip install --no-cache-dir \
    sympy==1.12.1

# Switch to sandbox user
USER sandbox

# Set working directory
WORKDIR /workspace

# Default entrypoint
ENTRYPOINT ["python", "-c"]
