#!/bin/sh
# schema-check — Validate all JSON Schema files and fixtures
# Usage: ./scripts/schema-check
# Uses the Rust schema-validator tool for full JSON Schema validation.
# Falls back to basic Python checks if the Rust tool is unavailable.

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
. "$SCRIPT_DIR/lib/colors.sh"

SCHEMAS_DIR="./schemas"

echo "=== Schema Validation ==="

# Try the Rust schema-validator tool first
if command -v cargo >/dev/null 2>&1; then
    if cargo run --bin schema-validator -- "$SCHEMAS_DIR" 2>/dev/null; then
        pass "All schemas valid (Rust validator)."
        exit 0
    fi
fi

# Fallback: basic Python validation
warn "Rust schema-validator not available; using basic Python checks."

FIXTURES_DIR="$SCHEMAS_DIR/fixtures"
ERRORS=0

for schema_file in "$SCHEMAS_DIR"/*.schema.json; do
    if [ ! -f "$schema_file" ]; then
        warn "No schema files found"
        break
    fi

    basename=$(basename "$schema_file")

    if ! python3 -m json.tool "$schema_file" >/dev/null 2>&1; then
        fail "$basename — invalid JSON syntax"
        ERRORS=$((ERRORS + 1))
        continue
    fi

    if ! python3 -c "
import json, sys
s = json.load(open('$schema_file'))
assert '\$schema' in s, 'Missing \$schema'
assert '\$id' in s, 'Missing \$id'
assert 'version' in s, 'Missing version field'
" 2>&1; then
        fail "$basename — missing required fields"
        ERRORS=$((ERRORS + 1))
        continue
    fi

    pass "$basename"
done

if [ -d "$FIXTURES_DIR" ]; then
    echo ""
    echo "--- Fixture Validation ---"

    for fixture_dir in "$FIXTURES_DIR"/*/; do
        [ -d "$fixture_dir" ] || continue
        schema_name=$(basename "$fixture_dir")

        for valid_file in "$fixture_dir"/valid-*.json; do
            [ -f "$valid_file" ] || continue
            if python3 -m json.tool "$valid_file" >/dev/null 2>&1; then
                pass "$schema_name/$(basename "$valid_file")"
            else
                fail "$schema_name/$(basename "$valid_file") — invalid JSON"
                ERRORS=$((ERRORS + 1))
            fi
        done

        for invalid_file in "$fixture_dir"/invalid-*.json; do
            [ -f "$invalid_file" ] || continue
            if python3 -m json.tool "$invalid_file" >/dev/null 2>&1; then
                pass "$schema_name/$(basename "$invalid_file")"
            else
                fail "$schema_name/$(basename "$invalid_file") — invalid JSON"
                ERRORS=$((ERRORS + 1))
            fi
        done
    done
fi

echo ""
if [ "$ERRORS" -gt 0 ]; then
    fail "$ERRORS validation error(s) found."
    exit 1
else
    pass "All schemas valid."
fi
