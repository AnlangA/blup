# =============================================================================
# Blup 环境变量配置
# 复制此文件为 .env 并填入你的值
#   cp .env.example .env
# =============================================================================

# ---- LLM Provider 配置 (至少配一个) ----

# OpenAI / OpenAI-compatible API (vLLM, Ollama, DeepSeek, 等)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1       # 默认 OpenAI，可改为自定义地址

# Anthropic / Anthropic-compatible API
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=                              # 默认 Anthropic，可改为自定义地址

# ---- LLM Gateway 配置 ----
GATEWAY_SECRET=dev-secret-change-in-prod          # agent-core 与此必须一致
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=9000
GATEWAY_RATE_LIMIT_PER_MINUTE=60
GATEWAY_MAX_RETRIES=2

# ---- Agent Core 配置 (Rust) ----
BLUP_HOST=127.0.0.1
BLUP_PORT=3000
BLUP_LLM_GATEWAY_URL=http://127.0.0.1:9000        # gateway 地址
BLUP_LLM_GATEWAY_SECRET=dev-secret-change-in-prod  # 与 GATEWAY_SECRET 一致
BLUP_LLM_MODEL=gpt-4o                              # 模型名 ← 在这里改
BLUP_PROMPTS_DIR=./prompts
BLUP_SCHEMAS_DIR=./schemas
BLUP_DATA_DIR=./data
BLUP_LOG_FORMAT=pretty
BLUP_MAX_SESSIONS=1000
BLUP_SESSION_TTL_HOURS=24

# ---- 示例 ----
# 用 OpenAI:
#   OPENAI_API_KEY=sk-xxx
#   BLUP_LLM_MODEL=gpt-4o
#
# 用 Anthropic:
#   ANTHROPIC_API_KEY=sk-ant-xxx
#   BLUP_LLM_MODEL=claude-sonnet-4-6
#
# 用本地 Ollama (OpenAI 兼容):
#   OPENAI_API_KEY=ollama
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   BLUP_LLM_MODEL=llama3
#
# 用 DeepSeek (OpenAI 兼容):
#   OPENAI_API_KEY=sk-xxx
#   OPENAI_BASE_URL=https://api.deepseek.com/v1
#   BLUP_LLM_MODEL=deepseek-chat
